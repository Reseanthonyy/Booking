{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=booking_db;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "SuperSecretKeyForDevelopment_AtLeast32Characters!",
    "Issuer": "BookingApi",
    "Audience": "BookingApiUsers",
    "ExpirationMinutes": 120
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "WriteTo": [
    {"Name": "Console"},
    {
      "Name": "File",
      "Args": {
        "path": "logs/log-.txt",
        "rollingInterval": "Day"
      }
    }
  ],
  "AllowedHosts": "*"
}
